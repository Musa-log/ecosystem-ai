{
  "name": "Ecosystem AI - Ollama + OpenClaude + Supabase",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:20",
  
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },

  "postCreateCommand": "npm install && echo '✅ Instalando Ollama...' && curl -fsSL https://ollama.com/install.sh | sh",

  "forwardPorts": [11434, 54321],
  
  "portsAttributes": {
    "11434": {
      "label": "Ollama",
      "onAutoForward": "notify"
    }
  },

  "remoteEnv": {
    "OLLAMA_HOST": "0.0.0.0"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker",
        "dbaeumer.vscode-eslint",
        "github.copilot",
        "github.copilot-chat"
      ]
    }
  }
}
